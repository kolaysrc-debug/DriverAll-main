{
  "name": "drivercv-backend",
  "version": "1.0.0",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:reset": "cmd /c \"for /f \"\"tokens=5\"\" %%a in ('netstat -ano ^| findstr :3001 ^| findstr LISTENING') do taskkill /F /PID %%a >nul 2>nul & npm run dev\"",
    "test": "jest --testTimeout=10000",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "seed:admin": "node scripts/seedAdmin.js",
    "seed:demo": "node scripts/seedClosedBetaDemo.js",
    "seed:tasks:todo": "node scripts/seedInstructionTasksFromTodo.js",
    "seed:tasks:discussions": "node scripts/seedInstructionTasksFromDiscussions.js",
    "handoff:export": "node scripts/exportHandoff.js",
