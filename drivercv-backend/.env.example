# Kopyala: cp .env.example .env  (drivercv-backend dizininde)
# Docker production compose bu dosyayı env_file olarak okur.

# MongoDB (yerelde 27017; Docker içinde compose MONGO_URI verir)
MONGO_URI=mongodb://127.0.0.1:27017/driverall
# MONGODB_URI=mongodb://user:pass@host:27017/driverall?authSource=admin

PORT=3001
NODE_ENV=development

# Zorunlu benzeri: production'da mutlaka güçlü değer
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=30d

# CORS: virgülle ayrılmış origin listesi
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

RATE_LIMIT_RPM=200
AUTH_RATE_LIMIT_RPM=15

# Opsiyonel: OAuth (set edilmezse strateji yüklenmez)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# OTP / Twilio (opsiyonel)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=

# OTP şifreleme anahtarı (üretimde zorunlu olabilir)
# OTP_SECRETS_MASTER_KEY=

# İlk admin seed (scripts/seedAdmin.js)
# DEFAULT_ADMIN_EMAIL=
# DEFAULT_ADMIN_PASSWORD=
