PS>try {
  Write-Host "ROOT   : $root"
  Write-Host "RESTORE: $restore"
  Write-Host "LOG    : $log"

  if (!(Test-Path $root)) { throw "Root not found: $root" }
  if (!(Test-Path $restore)) { throw "Restore not found: $restore" }

  $node = Get-Process node -ErrorAction SilentlyContinue
  if ($node) {
    Write-Host "WARN: node.exe processes are running. This can lock files." -ForegroundColor Yellow
    $node | Select-Object Id, ProcessName, Path, StartTime | Format-Table -AutoSize | Out-String | Write-Host
  }

  $fe = Join-Path $root 'drivercv-frontend'
  $be = Join-Path $root 'drivercv-backend'

  $feBakName = "drivercv-frontend__bak_$ts"
  $beBakName = "drivercv-backend__bak_$ts"
  $feBak = Join-Path $root $feBakName
  $beBak = Join-Path $root $beBakName

  if (Test-Path $fe) {
    Rename-Item -Path $fe -NewName $feBakName -ErrorAction Stop
    Write-Host "RENAMED: drivercv-frontend -> $feBakName"
  }
  if (Test-Path $be) {
    Rename-Item -Path $be -NewName $beBakName -ErrorAction Stop
    Write-Host "RENAMED: drivercv-backend  -> $beBakName"
  }

  $restoreFe = Join-Path $restore 'drivercv-frontend'
  $restoreBe = Join-Path $restore 'drivercv-backend'
  if (!(Test-Path $restoreFe)) { throw "Restore frontend folder missing: $restoreFe" }
  if (!(Test-Path $restoreBe)) { throw "Restore backend folder missing: $restoreBe" }

  Write-Host "COPY: frontend ..."
  robocopy $restoreFe $fe /MIR /XD node_modules .next /R:2 /W:1 /NP
  $rc = $LASTEXITCODE
  Write-Host "ROBOCOPY frontend exit code: $rc"
  if ($rc -ge 8) { throw "Robocopy frontend failed with code $rc" }

  Write-Host "COPY: backend (exclude .env) ..."
  robocopy $restoreBe $be /MIR /XD node_modules /XF .env /R:2 /W:1 /NP
  $rc = $LASTEXITCODE
  Write-Host "ROBOCOPY backend exit code: $rc"
  if ($rc -ge 8) { throw "Robocopy backend failed with code $rc" }

  $oldEnv = Join-Path $beBak '.env'
  $newEnv = Join-Path $be '.env'
  if (Test-Path $oldEnv) {
    Copy-Item -Force $oldEnv $newEnv
    Write-Host "ENV OK: copied .env from $beBakName"
  } else {
    Write-Host "WARN: previous .env not found at $oldEnv" -ForegroundColor Yellow
  }

  Write-Host 'DONE: 26 Feb restore completed.'
}
catch {
  Write-Host "ERROR: $($_.Exception.Message)" -ForegroundColor Red
  throw
}
